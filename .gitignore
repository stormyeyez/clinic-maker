# Exclude environment configuration/credentials
.env.*.local
*.pem
*.key
credentials.json
auth.json

# Exclude operating system/system files
.DS_Store
Thumbs.db
*.log
*.sqlite-journal

# Exclude local node and output dependencies
node_modules/
dist/
build/
output/
tmp/
temp/
.hermes/

# Exclude personal notes and requirement transcripts from being tracked in public git
requirements-draft/
conversations/
notes.md
*.tmp

.projects/cache
.projects/vault
.projects/state.test.json
.projects/state.local.test.json
.env
.env.*
!.env.example
.vercel

# Generated data — synthetic demo records only, not source; regenerate via db/db_init.py
app/db/database.sqlite
*.sqlite
*.sqlite3

